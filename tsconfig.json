{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* JSX */
    "jsx": "react-jsx",

    /* Paths */
    "paths": {
      "@/*": ["./src/*"],
      "@navet/core": ["./packages/core/src/index.ts"],
      "@navet/core/*": ["./packages/core/src/*"],
      "@navet/ui": ["./packages/ui/src/index.ts"],
      "@navet/ui/*": ["./packages/ui/src/*"],
      "@navet/app": ["./packages/app/src/index.ts"],
      "@navet/app/*": ["./packages/app/src/*"],
      "@navet/provider-homeassistant": ["./packages/provider-homeassistant/src/index.ts"],
      "@navet/provider-homeassistant/*": ["./packages/provider-homeassistant/src/*"],
      "@navet/provider-homey": ["./packages/provider-homey/src/index.ts"],
      "@navet/provider-homey/*": ["./packages/provider-homey/src/*"],
      "@navet/provider-hubitat": ["./packages/provider-hubitat/src/index.ts"],
      "@navet/provider-hubitat/*": ["./packages/provider-hubitat/src/*"],
      "@navet/provider-openhab": ["./packages/provider-openhab/src/index.ts"],
      "@navet/provider-openhab/*": ["./packages/provider-openhab/src/*"],
      "@navet/provider-smartthings": ["./packages/provider-smartthings/src/index.ts"],
      "@navet/provider-smartthings/*": ["./packages/provider-smartthings/src/*"],
      "@docker/*": ["./docker/*"],
      "@scripts/*": ["./scripts/*"]
    },

    /* Type declarations */
    "typeRoots": ["node_modules/@types", "src/types"]
  },
  "include": ["src", "packages"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
