{
  "name": "navet",
  "private": true,
  "version": "0.5.1",
  "description": "A smart home dashboard PWA for Home Assistant.",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/awesomestvi/navet#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/awesomestvi/navet.git"
  },
  "bugs": {
    "url": "https://github.com/awesomestvi/navet/issues"
  },
  "type": "module",
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
  "scripts": {
    "build": "pnpm --filter @navet/standalone build",
    "build:ha-panel": "node scripts/build-ha-panel.mjs",
    "build:demo": "pnpm --filter @navet/demo exec vite build --base=/demo/",
    "build:storybook": "pnpm storybook:build",
    "build:website": "pnpm website:bundle",
    "dev": "pnpm --filter @navet/standalone dev",
    "website:build": "pnpm website:bundle",
    "website:build:app": "pnpm --filter @navet/website build",
    "website:bundle": "pnpm website:build:app && pnpm build:demo && pnpm storybook:build && node scripts/stage-website-bundle.mjs",
    "website:dev": "pnpm --filter @navet/website dev",
    "website:preview": "pnpm --filter @navet/website preview",
    "docker:build": "docker build -t navet:local .",
    "docker:smoke": "node scripts/docker-smoke.mjs",
    "release:linear": "node scripts/fetch-linear-release-issues.mjs",
    "release:check": "node scripts/check-release-surfaces.mjs",
    "release:notes": "node scripts/extract-release-notes.mjs",
    "release:version-sync": "node scripts/sync-release-versions.mjs",
    "export:hacs": "node scripts/export-hacs-integration.mjs",
    "release:export-hacs": "node scripts/export-hacs-integration.mjs",
    "wallpapers:audit": "node scripts/wallpapers.mjs audit",
    "wallpapers:optimize": "node scripts/wallpapers.mjs optimize",
    "wallpapers:check": "node scripts/wallpapers.mjs check",
    "preview": "pnpm build && pnpm preview:config && pnpm --filter @navet/standalone preview",
    "preview:config": "node scripts/write-preview-config.mjs",
    "clean:root": "node scripts/clean-root-artifacts.mjs",
    "clean:all": "node scripts/clean-root-artifacts.mjs --all",
    "storybook": "STORYBOOK=1 HOME=$PWD/.cache/storybook/home XDG_CONFIG_HOME=$PWD/.cache/storybook STORYBOOK_DISABLE_TELEMETRY=1 pnpm --filter @navet/storybook run storybook",
    "storybook:build": "STORYBOOK=1 STORYBOOK_BASE_PATH=/storybook/ HOME=$PWD/.cache/storybook/home XDG_CONFIG_HOME=$PWD/.cache/storybook STORYBOOK_DISABLE_TELEMETRY=1 pnpm --filter @navet/storybook run build",
    "build-storybook": "pnpm storybook:build",
    "lint": "biome lint ./packages",
    "format": "biome format --write ./packages",
    "check": "biome check ./packages",
    "check:stories": "node scripts/check-storybook-standards.mjs",
    "check:ui-kit": "node scripts/check-ui-kit-boundaries.mjs",
    "check:provider-boundaries": "node scripts/check-provider-boundaries.mjs",
    "check:docker": "node scripts/check-docker-runtime.mjs",
    "check:lockfile": "node scripts/check-pnpm-lock-sync.mjs",
    "check:commitmsg": "node scripts/check-commit-message.mjs",
    "check:fix": "biome check --apply ./packages",
    "report:bundle": "node scripts/inspect-bundle.mjs",
    "report:ui-kit": "node scripts/check-ui-kit-usage.mjs",
    "test": "vitest --config vitest.unit.config.ts --project unit",
    "test:tier1": "vitest --config vitest.unit.config.ts --project unit --run packages/provider-homeassistant/src/homeassistant-contract.test.ts packages/provider-homey/src/homey-contract.test.ts packages/provider-openhab/src/openhab-contract.test.ts packages/provider-hubitat/src/planned-provider-contract.test.ts packages/app/src/auth/__tests__/adapters.test.ts packages/app/src/auth/__tests__/runtime.test.ts packages/app/src/auth/__tests__/homeAssistantDiscovery.test.ts packages/app/src/auth/__tests__/homey-oauth-auth.test.ts packages/app/src/infrastructure/home-assistant/resources/__tests__/resource-resolver.test.ts packages/app/src/utils/__tests__/home-assistant-url.test.ts packages/app/src/utils/__tests__/rss-proxy-security.test.ts packages/app/src/features/auth/__tests__/login-page.test.tsx packages/app/src/features/media/components/media-card/__tests__/use-media-artwork-resolution.test.tsx packages/app/src/features/security/components/camera-card/__tests__/camera-stream-player.test.tsx packages/app/src/features/rss/components/rss-feed-card/__tests__/use-rss-feed-items.test.tsx packages/app/src/stores/__tests__/integration-store.test.ts packages/app/src/services/__tests__/integration-runtime.service.test.ts packages/app/src/services/__tests__/integration-registry.service.test.ts packages/app/src/services/__tests__/integration-action.service.test.ts",
    "test:tier2": "vitest --config vitest.unit.config.ts --project unit --run packages/app/src/platform/__tests__/provider-room-management.test.ts packages/app/src/stores/__tests__/home-assistant-store.test.ts packages/app/src/stores/__tests__/settings-store.test.ts packages/app/src/services/__tests__/dashboard-endpoints.test.ts packages/app/src/services/__tests__/ha-connection.service.test.ts packages/app/src/services/__tests__/ha-entity-service.test.ts packages/app/src/services/__tests__/ha-registry.service.test.ts packages/app/src/services/__tests__/home-assistant-energy-feature.service.test.ts packages/app/src/services/__tests__/home-assistant-panel-adapter.test.ts packages/app/src/services/__tests__/homey.service.test.ts packages/app/src/services/__tests__/integration-admin.service.test.ts packages/app/src/services/__tests__/integration-bootstrap.service.test.ts packages/app/src/services/__tests__/integration-calendar-feature.service.test.ts packages/app/src/services/__tests__/integration-camera-feature.service.test.ts packages/app/src/services/__tests__/integration-history.service.test.ts packages/app/src/services/__tests__/integration-light-feature.service.test.ts packages/app/src/services/__tests__/integration-media-feature.service.test.ts packages/app/src/services/__tests__/integration-notification-feature.service.test.ts packages/app/src/services/__tests__/integration-resource.service.test.ts packages/app/src/services/__tests__/integration-security-feature.service.test.ts packages/app/src/services/__tests__/integration-task.service.test.ts packages/app/src/services/__tests__/integration-weather-feature.service.test.ts",
    "test:tier3": "vitest --config vitest.unit.config.ts --project unit",
    "test:coverage": "vitest --config vitest.unit.config.ts --project unit --coverage",
    "test:storybook": "vitest --project \"storybook:$PWD/apps/storybook/.storybook\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-slider": "1.3.6",
    "clsx": "2.1.1",
    "hls.js": "^1.6.16",
    "home-assistant-js-websocket": "^9.6.0",
    "leaflet": "^1.9.4",
    "lucide-react": "1.16.0",
    "react-leaflet": "^5.0.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "workbox-window": "^7.4.1",
    "yaml": "^2.9.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@rolldown/plugin-babel": "^0.2.0",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "10.4.0",
    "@storybook/addon-vitest": "^10.4.0",
    "@storybook/react": "10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/browser-playwright": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.6",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "sharp": "^0.34.5",
    "storybook": "^10.4.0",
    "tailwindcss": "4.3.0",
    "typescript": "^6.0.3",
    "vite": "8.0.13",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
