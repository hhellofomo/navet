{
  "name": "navet",
  "private": true,
  "version": "0.7.12",
  "description": "A smart home dashboard PWA for Home Assistant.",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/awesomestvi/navet#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/awesomestvi/navet.git"
  },
  "bugs": {
    "url": "https://github.com/awesomestvi/navet/issues"
  },
  "type": "module",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "scripts": {
    "build": "pnpm --filter @navet/standalone build",
    "build:ha-panel": "node scripts/build-ha-panel.mjs",
    "push:ha-panel": "zsh scripts/push-ha-panel.sh",
    "reset:ha-panel-assets": "zsh scripts/reset-ha-panel-assets.sh",
    "build:demo": "pnpm --filter @navet/demo exec vite build --base=/demo/",
    "build:storybook": "pnpm storybook:build",
    "build:website": "pnpm website:bundle",
    "dev": "pnpm --filter @navet/standalone dev",
    "demo:dev": "pnpm --filter @navet/demo dev",
    "website:build": "pnpm website:bundle",
    "website:build:app": "pnpm --filter @navet/website build",
    "website:bundle": "pnpm website:build:app && pnpm build:demo && pnpm storybook:build && node scripts/stage-website-bundle.mjs",
    "website:dev": "pnpm --filter @navet/website dev",
    "website:preview": "pnpm --filter @navet/website preview",
    "docker:build": "docker build -t navet:local .",
    "docker:smoke": "node scripts/docker-smoke.mjs",
    "release:linear": "node scripts/fetch-linear-release-issues.mjs",
    "release:check": "node scripts/check-release-surfaces.mjs",
    "release:notes": "node scripts/extract-release-notes.mjs",
    "release:version-sync": "node scripts/sync-release-versions.mjs",
    "release:dev-version": "node scripts/set-dev-addon-version.mjs",
    "release:dev-publish": "node scripts/create-dev-release.mjs",
    "export:hacs": "node scripts/export-hacs-integration.mjs",
    "sync:hacs": "node scripts/sync-hacs-repo.mjs",
    "release:export-hacs": "node scripts/export-hacs-integration.mjs",
    "wallpapers:audit": "node scripts/wallpapers.mjs audit",
    "wallpapers:optimize": "node scripts/wallpapers.mjs optimize",
    "wallpapers:check": "node scripts/wallpapers.mjs check",
    "preview": "pnpm build && pnpm preview:config && pnpm --filter @navet/standalone preview",
    "preview:config": "node scripts/write-preview-config.mjs",
    "clean:root": "node scripts/clean-root-artifacts.mjs",
    "clean:all": "node scripts/clean-root-artifacts.mjs --all",
    "storybook": "STORYBOOK=1 HOME=$PWD/.cache/storybook/home XDG_CONFIG_HOME=$PWD/.cache/storybook STORYBOOK_DISABLE_TELEMETRY=1 pnpm --filter @navet/storybook run storybook",
    "storybook:build": "STORYBOOK=1 STORYBOOK_BASE_PATH=/storybook/ HOME=$PWD/.cache/storybook/home XDG_CONFIG_HOME=$PWD/.cache/storybook STORYBOOK_DISABLE_TELEMETRY=1 pnpm --filter @navet/storybook run build",
    "build-storybook": "pnpm storybook:build",
    "lint": "biome lint ./packages",
    "format": "biome format --write ./packages",
    "check": "biome check ./packages",
    "check:stories": "node scripts/check-storybook-standards.mjs",
    "check:ui-kit": "node scripts/check-ui-kit-boundaries.mjs",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "check:provider-boundaries": "node scripts/check-provider-boundaries.mjs",
    "check:docker": "node scripts/check-docker-runtime.mjs",
    "check:lockfile": "node scripts/check-pnpm-lock-sync.mjs",
    "check:commitmsg": "node scripts/check-commit-message.mjs",
    "validate": "node scripts/validate-scope.mjs",
    "check:fix": "biome check --apply ./packages",
    "report:bundle": "node scripts/inspect-bundle.mjs",
    "report:ui-kit": "node scripts/check-ui-kit-usage.mjs",
    "test": "vitest --config vitest.unit.config.ts --project unit",
    "test:tier1": "node scripts/run-test-tier.mjs tier1",
    "test:tier2": "node scripts/run-test-tier.mjs tier2",
    "test:tier3": "node scripts/run-test-tier.mjs tier3",
    "test:coverage": "vitest --config vitest.unit.config.ts --project unit --coverage",
    "test:storybook": "vitest --project \"storybook:$PWD/apps/storybook/.storybook\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-alert-dialog": "1.1.17",
    "@radix-ui/react-avatar": "1.2.0",
    "@radix-ui/react-checkbox": "1.3.5",
    "@radix-ui/react-dialog": "1.1.17",
    "@radix-ui/react-dropdown-menu": "2.1.18",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "2.1.10",
    "@radix-ui/react-popover": "1.1.17",
    "@radix-ui/react-scroll-area": "1.2.12",
    "@radix-ui/react-slider": "1.4.1",
    "clsx": "2.1.1",
    "hls.js": "^1.6.16",
    "home-assistant-js-websocket": "^9.6.0",
    "leaflet": "^1.9.4",
    "lucide-react": "1.21.0",
    "react-leaflet": "^5.0.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "workbox-window": "^7.4.1",
    "yaml": "^2.9.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react": "10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "sharp": "^0.35.2",
    "storybook": "^10.4.6",
    "tailwindcss": "4.3.1",
    "typescript": "^6.0.3",
    "vite": "8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
