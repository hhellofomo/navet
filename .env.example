NAVET_HASS_URL=http://homeassistant.local:8123
# Runtime credential for Docker/add-on deployments. Do not expose this in public static builds.
NAVET_HASS_TOKEN=your-long-lived-access-token
# Optional Homey OAuth settings for standalone Docker/Homey development.
NAVET_HOMEY_CLIENT_ID=
NAVET_HOMEY_CLIENT_SECRET=
# Optional override. Navet derives the callback URL from the current origin by default.
NAVET_HOMEY_REDIRECT_URI=
# Optional dashboard YAML export to auto-import for fresh browsers.
NAVET_DASHBOARD_CONFIG_URL=
